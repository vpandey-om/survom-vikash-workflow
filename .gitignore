*.py[cod]

# Python cache
__pycache__/
*.py[cod]

# Local Docker / container exports
*.tar
*.tar.gz
*.oci
image-archives/

# Local workflow outputs and temporary files
/tmp/
results/
work/
.nextflow/
.nextflow.log*
.nextflow.cache/

# Local runtime data and logs
logs/
docker-data/
survom-storage/
