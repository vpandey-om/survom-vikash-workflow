# External sequencing / omics data — never commit
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.cram
*.sam
*.vcf
*.vcf.gz
*.bcf
*.bed
*.gff
*.gtf
*.fasta
*.fa
*.fna
*.fastq.zst

# Keep tiny synthetic test fixtures tracked
!tests/
!tests/fixtures/
!tests/fixtures/**/*.fastq
!tests/fixtures/**/*.fastq.gz
!tests/fixtures/**/*.fq
!tests/fixtures/**/*.fq.gz
